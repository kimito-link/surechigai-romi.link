# ============================================================
# すれちがいロミ 環境変数サンプル
# このファイルをコピーして .env.local を作成してください。
# .env.local は .gitignore に含まれているため、Git には含まれません。
# ============================================================

# ------------------------------------------------------------
# Supabase (Postgres) — 接続文字列
# 取得手順:
#   1. https://supabase.com でプロジェクトを作成
#   2. プロジェクト設定 > Database > Connection string > URI を選択
#   3. "Transaction pooler" (ポート 6543) を使用（Vercel Functions 向け）
#      例: postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
#   4. 以下の DATABASE_URL に貼り付ける
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ------------------------------------------------------------
# Clerk (認証)
# https://dashboard.clerk.com > プロジェクト > API Keys
# ------------------------------------------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ------------------------------------------------------------
# Twitter / X OAuth 2.0
# https://developer.twitter.com/en/portal/dashboard
# Callback URL: https://surechigai-romi.link/oauth/twitter-callback
# (開発時: http://localhost:8081/oauth/twitter-callback)
# ------------------------------------------------------------
TWITTER_CLIENT_ID=...
TWITTER_CLIENT_SECRET=...

# ------------------------------------------------------------
# セキュリティ
# openssl rand -hex 32 で生成
# ------------------------------------------------------------
ENCRYPTION_KEY=your-64-char-hex-key-here
SESSION_SECRET=your-random-session-secret

# ------------------------------------------------------------
# サーバー設定
# ------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------
# Sentry (エラー監視) — オプション
# ------------------------------------------------------------
# SENTRY_DSN=https://...

# ------------------------------------------------------------
# Groq API (ひとことモデレーション)
# https://console.groq.com
# ------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# Gemini API (演出文・モデレーション控え)
# https://aistudio.google.com
# ------------------------------------------------------------
# GEMINI_API_KEY=AIza...
