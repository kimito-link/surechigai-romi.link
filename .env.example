# ============================================================
# 君斗りんくのすれ違ひ通信 環境変数サンプル
# このファイルをコピーして .env.local を作成してください。
# .env.local は .gitignore に含まれているため、Git には含まれません。
# ============================================================

# ------------------------------------------------------------
# Supabase (Postgres) — 接続文字列
# 取得手順:
#   1. https://supabase.com でプロジェクトを作成
#   2. プロジェクト設定 > Database > Connection string > URI を選択
#   3. "Transaction pooler" (ポート 6543) を使用（Vercel Functions 向け）
#      例: postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
#   4. 以下の DATABASE_URL に貼り付ける
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ------------------------------------------------------------
# Clerk (認証)
# https://dashboard.clerk.com > プロジェクト > API Keys
# ------------------------------------------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- Clerk: kimito.link 本番インスタンスを共有する ---
# 配信ホスト名で到達方法が「実行時に」自動分岐するため、通常これらの設定は不要。
#
#  (本命) *.kimito.link で配信(例: surechigai.kimito.link):
#      同一サイトなので Cookie が .kimito.link で共有され、satellite も proxy も不要。
#      ログインがシームレス＝リロードの白画面(同期リダイレクト)も起きない。
#      → 何も設定しなくて良い。Clerk Dashboard 側で当該サブドメインを
#        allowed origins / allowedRedirectOrigins に含めておくこと。
#
#  (移行期の後方互換) surechigai-romi.link 等の別ドメインで配信:
#      自動で satellite + /__clerk(api/clerk-proxy)プロキシ方式になる。
#      proxyUrl は実行時に `${origin}/__clerk` を自動導出するため設定不要。
#      Clerk Dashboard(primary) に satellite ドメインを proxy_url 付きで登録しておくこと。
#
# 任意の上書き:
#   EXPO_PUBLIC_CLERK_SIGN_IN_URL : primary のサインインURL(既定 https://kimito.link/sign-in/)
#   EXPO_PUBLIC_CLERK_IS_SATELLITE="false" : 別ドメインでも satellite を切る(単独インスタンス検証用)
# EXPO_PUBLIC_CLERK_SIGN_IN_URL=https://kimito.link/sign-in/
# EXPO_PUBLIC_CLERK_IS_SATELLITE=true

# ------------------------------------------------------------
# Twitter / X OAuth 2.0
# https://developer.twitter.com/en/portal/dashboard
# Callback URL: https://surechigai-romi.link/oauth/twitter-callback
# (開発時: http://localhost:8081/oauth/twitter-callback)
# ------------------------------------------------------------
TWITTER_CLIENT_ID=...
TWITTER_CLIENT_SECRET=...

# ------------------------------------------------------------
# セキュリティ
# openssl rand -hex 32 で生成
# ------------------------------------------------------------
ENCRYPTION_KEY=your-64-char-hex-key-here
SESSION_SECRET=your-random-session-secret

# ------------------------------------------------------------
# サーバー設定
# ------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------
# スイープ Webhook セキュリティトークン
# GitHub Actions から /api/sweep を叩くときの認証トークン
# openssl rand -hex 32 で生成
# GitHub Actions secrets の SWEEP_SECRET と同じ値を設定する
# ------------------------------------------------------------
SWEEP_SECRET=your-sweep-secret-here

# ------------------------------------------------------------
# API ベース URL (GitHub Actions スイープ用)
# 本番: https://surechigai-romi.link
# 開発: http://localhost:3000
# ------------------------------------------------------------
API_BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Sentry (エラー監視) — オプション
# ------------------------------------------------------------
# SENTRY_DSN=https://...

# ------------------------------------------------------------
# Groq API (ひとことモデレーション)
# https://console.groq.com
# ------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# ------------------------------------------------------------
# Gemini API (演出文・モデレーション控え)
# https://aistudio.google.com
# ------------------------------------------------------------
# GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# OGP 地図サムネ (/api/og) のタイル提供元 — オプション
# 未設定なら OSM 標準タイル（キー不要）を使用。
# MapTiler のキーを設定すると実写寄りの高品質タイルに自動で切り替わる。
# https://cloud.maptiler.com/account/keys/ （無料枠あり）
# MAPTILER_STYLE は任意（既定 streets-v2。例: hybrid で航空写真寄り）
# ------------------------------------------------------------
# MAPTILER_KEY=your-maptiler-key
# MAPTILER_STYLE=streets-v2
