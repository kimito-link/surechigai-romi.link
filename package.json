{
  "name": "surechigai-romi",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "type": "module",
  "main": "expo-router/entry",
  "sideEffects": [
    "app/_layout.tsx",
    "lib/bootstrap/**",
    "*.css",
    "global.css",
    "scripts/**",
    "server/**",
    "babel-plugins/**"
  ],
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development node --import tsx server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_PORT=8081 npx expo start --web --port 8081",
    "build": "node scripts/generate-build-info.cjs && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && node scripts/copy-build-info.cjs",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "postinstall": "node scripts/strip-import-meta.cjs",
    "lint": "expo lint --max-warnings 9999",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "node scripts/run-drizzle.cjs push",
    "db:migrate": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/migrate.ts",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "qr": "node scripts/generate_qr.mjs",
    "e2e": "playwright test --project=public-smoke --project=trail-auth-smoke --project=events-host-smoke --project=audit-guest-mobile --project=audit-guest-desktop",
    "e2e:audit": "playwright test --project=audit-guest-mobile --project=audit-guest-desktop --project=audit-auth-mobile --project=audit-auth-desktop",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:auth-save": "playwright test --project=save-auth --headed",
    "diff-check": "node scripts/diff-check.mjs",
    "pagespeed": "node scripts/pagespeed-check.mjs --categories=performance",
    "pagespeed:full": "node scripts/pagespeed-check.mjs",
    "brand:icons": "python scripts/sync-brand-icons.py",
    "contrast:audit": "node scripts/contrast-audit.mjs",
    "pagespeed:a11y": "node scripts/pagespeed-a11y-routes.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.4",
    "@clerk/expo": "^3.0.1",
    "@clerk/express": "^2.0.1",
    "@clerk/localizations": "^4.11.0",
    "@clerk/react": "6.0.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.8.12",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.25",
    "@sentry/nextjs": "^10.37.0",
    "@sentry/node": "^10.37.0",
    "@sentry/profiling-node": "^10.37.0",
    "@sentry/react": "^10.37.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vercel/og": "^0.11.1",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "expo": "~54.0.29",
    "expo-audio": "~1.1.0",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "^1.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.12",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "^56.0.17",
    "expo-notifications": "~0.32.15",
    "expo-router": "~6.0.19",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.15",
    "expo-web-browser": "~15.0.10",
    "express": "^4.22.1",
    "h3-js": "^4.4.0",
    "jose": "6.1.0",
    "mysql2": "^3.22.5",
    "nativewind": "^4.2.1",
    "openapi-types": "^12.1.3",
    "pg": "^8.13.1",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "0.2.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^1.13.3",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^2.6.0",
    "trpc-openapi": "^1.2.0",
    "ws": "^8.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "@types/react-test-renderer": "^19.1.0",
    "@types/testing-library__react": "^10.2.0",
    "@vercel/node": "^5.5.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "expo-atlas": "^0.4.3",
    "jsdom": "^27.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "qrcode": "^1.5.4",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0"
}
